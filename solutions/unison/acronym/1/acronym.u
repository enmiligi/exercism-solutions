acronym.abbreviate : Text -> Text
acronym.abbreviate test = 
    withoutPunctuation = Text.join "" (List.map (c -> match c with
                                                c | isLetter c -> Char.toText(c)
                                                  | c === ?\s -> " "
                                                  | c === ?- -> "-"
                                                _ -> "")(toCharList test))
    Text.join "" (List.map (word -> Optional.getOrElse "" (Optional.map (Char.toUppercase >> Char.toText) (Text.charAt 0 word))) (Text.split ?\s withoutPunctuation))
