.globl scrabble_score
.data
scores: .byte 1, 3, 3, 2, 1, 4, 2, 4, 1, 8, 5, 1, 3, 1, 1, 3, 10, 1, 1, 1, 1, 4, 4, 8, 4, 10
.text
scrabble_score:
li $v0, 0
loop:
lbu $t1, ($a0)
beqz $t1, ret
ori $t1, $t1, 0x20 # convert to lowercase
sub $t1, $t1, 'a'
lb $t2, scores($t1)
add $v0, $v0, $t2
add $a0, $a0, 1
j loop
ret:
jr $ra